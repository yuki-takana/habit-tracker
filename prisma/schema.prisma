generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
}

model Waitlist {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  name              String?
  email             String?       @unique
  password          String?
  phone             String? // Store in E.164 format (e.g., "+919876543210")
  whatsappEnabled   Boolean       @default(false)
  dailyGoalsEnabled Boolean       @default(true)
  emailVerified     DateTime?
  image             String?
  wakatimeApiKey    String?
  githubApiKey      String?
  linkedinApiKey    String?
  twitterApiKey     String?
  accounts          Account[]
  sessions          Session[]
  // Add your app-specific fields here
  habits            Habit[]
  tasks             Task[]
  todos             Todo[]
  wakaTimeStats     WakaTime[]
  workoutPlans      WorkoutPlan[]
  chatMessages      ChatMessage[]

  height      Float?
  weight      Float?
  fitnessGoal String? // "Bulking", "Cutting", "Strength"
  experience  String? // "Beginner", "Intermediate"

  incomePlans            IncomePlan[]
  projectPlans           ProjectPlan[]
  careerPlans            CareerPlan[]
  userProfile            UserProfile?
  feedbacks              UserFeedback[]
  replanLogs             ReplanLog[]
  businessPlans          BusinessPlan[]
  healthPlans            HealthPlan[]
  learningPlans          LearningPlan[]
  mindsetPlans           MindsetPlan[]
  productivityPlans      ProductivityPlan[]
  relationshipPlans      RelationshipPlan[]
  agentConversations     AgentConversation[]
  userGoals              UserGoal[]
  agentMemories          AgentMemory[]
  networkingPlans        NetworkingPlan[]
  blueprintTasks         BlueprintTask[]
  lifePlans              LifePlan[]
  subscription           Subscription?
  challenges             Challenge[]
  todoSessions           TodoSession[]
  totalStreakDays        Int                 @default(0)
  streakShields          Int                 @default(0)
  streakShieldContinuity Int                 @default(0) // Days with 50-60%+ todo completion
  xp                     Int                 @default(0)
  level                  Int                 @default(1) // Gamification progression level
  autoShieldEnabled      Boolean             @default(true)
  lastGraceActivation    DateTime?

  agentUsageCount        Int                 @default(0)
  streakRestoreCount     Int                 @default(0)
  agentPurchases         AgentPurchase[]
  agentRecords           AgentRecord[]

  roleLevel          Int       @default(0)
  roleTitle          String    @default("Beginner")
  lastProgressUpdate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  progressTrees ProgressTree[]
  userRoles     UserRole[]
}

model UserRole {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  role        String // "Developer", "Fitness", "Entrepreneur", etc.
  targetHours Int // weekly goal
  actualHours Float    @default(0)
  weekStart   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressTree {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  type        String // "habit", "challenge", "overall"
  referenceId String?   @db.ObjectId // habitId or challengeId
  trees       Json // array of tree growth stages
  lastWatered DateTime?
  growthLevel Int       @default(0)
  state       String    @default("alive") // "alive", "ghost", "retired"
  stage       Int       @default(0) // 0 to 7
  status      String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  name            String
  description     String?
  category        String?
  frequency       String   @default("daily") // daily, weekly
  autoCreateTodos Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  streakCount       Int       @default(0)
  longestStreak     Int       @default(0)
  lastCompletedDate DateTime?
}

model HabitLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  habitId   String   @db.ObjectId
  date      DateTime
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String?
  category    String? // Code, Fitness, Freelance, Growth, etc.
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending") // pending, in-progress, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @db.ObjectId
  task             String
  category         String?
  startTime        DateTime?
  plannedTime      Int? 
  deadline         DateTime?
  reminderTime     DateTime?
  earnedXp         Int           @default(0)
  extraTime        Int?
  status           String        @default("upcoming")
  startedAt        DateTime?
  delayCount       Int           @default(0)
  lastDelayedAt    DateTime?
  whatsappNotified Boolean       @default(false)
  completed        Boolean       @default(false)
  completedAt      DateTime?
  habitId          String?       @db.ObjectId
  challengeId      String?       @db.ObjectId
  isAIGenerated    Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  sessions         TodoSession[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TodoSession {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  todoId String @db.ObjectId
  userId String @db.ObjectId

  startedAt DateTime?
  endedAt   DateTime?

  targetDuration Int // duration in minutes
  breakDuration  Int @default(0) // break in minutes after this session
  order          Int @default(0)

  duration Int? // actual duration in minutes (computed when session ends)

  status SessionStatus @default(PENDING)

  pauseTime Int @default(0) // seconds paused
  extraTime Int @default(0) // overtime used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todo Todo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WakaTime {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  date       DateTime
  totalTime  String
  projects   Json
  languages  Json
  categories Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model WorkoutPlan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  goal       String // e.g., "Full Body Hypertrophy"
  weekNumber Int // To track Week 1, Week 2, etc.
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workouts Workout[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  planId      String    @db.ObjectId
  dayOfWeek   String // "Monday"
  focus       String // "Chest + Triceps"
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  exercises   WorkoutExercise[]
  workoutPlan WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model WorkoutExercise {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  workoutId     String  @db.ObjectId
  exerciseId    String
  name          String // e.g., "Bench Press"
  sets          Int
  reps          Int
  weight        Float? // The weight assigned by the AI
  gifUrl        String? // From ExerciseDB
  notes         String? // Form tips from the Researcher Agent
  completedSets Int     @default(0)

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  profession    String?
  skills        String[]
  monthlyIncome Float?
  fitnessLevel  String?
  primaryGoal   String?
  wakeUpTime    String?  @default("06:30")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomePlan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  goal         String
  targetAmount Float
  strategy     String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  weeks IncomeWeek[]
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomeWeek {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  planId         String   @db.ObjectId
