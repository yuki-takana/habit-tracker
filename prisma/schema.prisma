model ProjectTask {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  phaseId        String    @db.ObjectId
  dayNumber      Int
  title          String
  description    String
  estimatedHours Float
  type           String // "frontend" | "backend" | "design" | "testing" | "deployment"
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  phase ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model UserFeedback {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @db.ObjectId
  feedback            String
  sentiment           String // "positive" | "neutral" | "negative" | "overwhelmed" | "motivated"
  planType            String // "gym" | "income" | "project" | "career" | "general"
