}

model NetworkingWeek {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  planId     String   @db.ObjectId
  weekNumber Int
  focus      String
  createdAt  DateTime @default(now())

  tasks NetworkingTask[]
  plan  NetworkingPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model NetworkingTask {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  weekId      String    @db.ObjectId
  dayNumber   Int?
  title       String
  description String
  platform    String? // "LinkedIn" | "Twitter" | "Email" | "Events"
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  deadline    DateTime?
  createdAt   DateTime  @default(now())

  week NetworkingWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
}

// ─── UNIFIED BLUEPRINT TASK (for cross-domain dashboard) ──────
model BlueprintTask {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  planId          String    @db.ObjectId
  planType        String
  weekNumber      Int
  dayNumber       Int?
  title           String
  description     String?
  expectedOutcome String?
  priority        Int       @default(1)
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  deadline        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, planId])
  @@index([planType])
}

model Subscription {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String    @unique @db.ObjectId
  status                 String // "active", "canceled", "past_due", "trialing", etc.
  planId                 String // Internal plan ID e.g., "free", "pro_monthly", "pro_yearly"
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  title           String
  focus           String
  description     String?
  durationDays    Int      @default(90)
  autoCreateTodos Boolean  @default(false)
  startDate       DateTime @default(now())
  endDate         DateTime
  status          String   @default("active") // active, completed, failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  streakCount    Int   @default(0)
  longestStreak  Int   @default(0)
  completionRate Float @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  role      String // "user" (you) or "assistant" (AI)
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentPurchase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  agentId     String
  purchasedAt DateTime @default(now())
  expiresAt   DateTime
  amountPaid  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  agentId     String
  isPurchased Boolean  @default(false)
  promptsUsed Int      @default(0)
  promptLimit Int      @default(5)
  purchasedAt DateTime?
  amountPaid  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}
